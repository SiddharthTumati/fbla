# Role-based access (comma-separated emails, lowercase)
VITE_ADMIN_EMAILS=you@gmail.com
VITE_OFFICER_EMAILS=officer1@gmail.com,officer2@gmail.com

# Chapter branding
VITE_CHAPTER_NAME=Riverside High FBLA

# Demo mode for judges (set false in production)
VITE_ENABLE_DEMO=true

# Supabase (https://supabase.com/dashboard/project/cttncecgjgxrttvwqmuq/settings/api)
# Use Project URL + anon public key in the app. Never commit real keys.
VITE_SUPABASE_URL=https://cttncecgjgxrttvwqmuq.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Direct Postgres (SQL Editor, migrations, server scripts only — NOT for Vite client)
# Session pooler (IPv4): see Dashboard → Connect → Session pooler
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres
